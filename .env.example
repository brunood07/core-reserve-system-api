# Development (postgres container - porta 5432)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/wow_reserve?schema=public"

# Test (postgres_test container - porta 5433)
DATABASE_URL_TEST="postgresql://postgres:postgres@localhost:5433/wow_reserve_test?schema=public"

NODE_ENV="development"
PORT=3333
HOST="0.0.0.0"
CORS_ORIGIN="http://localhost:3000"

# JWT — use secrets longos e distintos em produção
JWT_ACCESS_SECRET="change-me-access-secret"
JWT_REFRESH_SECRET="change-me-refresh-secret"
