generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  PLAYER
  RAID_LEADER
  OFFICER
  ADMIN
}

enum RaidStatus {
  DRAFT
  OPEN
  CLOSED
  COMPLETED
}

enum ReservationFormStatus {
  OPEN
  CLOSED
}

enum CharacterClass {
  WARRIOR
  PALADIN
  HUNTER
  ROGUE
  PRIEST
  DEATH_KNIGHT
  SHAMAN
  MAGE
  WARLOCK
  MONK
  DRUID
  DEMON_HUNTER
  EVOKER
}

enum ReserveStatus {
  ACTIVE
  CANCELLED
  FULFILLED
}

enum ItemType {
  HELM
  SHOULDER
  BACK
  CHEST
  WRIST
  HANDS
  WAIST
  LEGS
  FEET
  NECK
  FINGER
  TRINKET
  WEAPON
  SHIELD
  OFF_HAND
}

model User {
  id           String        @id @default(uuid())
  name         String
  email        String        @unique
  passwordHash String        @map("password_hash")
  role         UserRole      @default(PLAYER)
  deletedAt    DateTime?     @map("deleted_at")
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  refreshToken RefreshToken?
  characters   Character[]
  raids        Raid[]
  attendances  RaidAttendance[]

  @@map("users")
}

model RefreshToken {
  userId    String   @id @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model Raid {
  id          String     @id @default(uuid())
  date        DateTime   @unique
  description String?
  status      RaidStatus @default(DRAFT)
  createdById String     @map("created_by_id")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  createdBy   User              @relation(fields: [createdById], references: [id])
  bosses      Boss[]
  reserves    Reserve[]
  attendances RaidAttendance[]

  @@map("raids")
}

model RaidAttendance {
  id          String   @id @default(uuid())
  raidId      String   @map("raid_id")
  userId      String   @map("user_id")
  characterId String   @map("character_id")
  attended    Boolean
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  raid      Raid      @relation(fields: [raidId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id])
  character Character @relation(fields: [characterId], references: [id])

  @@unique([raidId, userId])
  @@map("raid_attendances")
}

model ReservationForm {
  id       String                @id @default(uuid())
  weekOf   DateTime              @unique @map("week_of")
  opensAt  DateTime              @map("opens_at")
  closesAt DateTime              @map("closes_at")
  status   ReservationFormStatus @default(OPEN)
  createdAt DateTime             @default(now()) @map("created_at")
  updatedAt DateTime             @updatedAt @map("updated_at")

  @@map("reservation_forms")
}

model Boss {
  id         String   @id @default(uuid())
  raidId     String   @map("raid_id")
  name       String
  orderIndex Int      @map("order_index")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  raid  Raid   @relation(fields: [raidId], references: [id], onDelete: Cascade)
  items Item[]

  @@unique([raidId, orderIndex])
  @@map("bosses")
}

model Item {
  id       String   @id @default(uuid())
  bossId   String   @map("boss_id")
  name     String
  itemType ItemType @map("item_type")
  ilvl     Int
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  boss Boss @relation(fields: [bossId], references: [id], onDelete: Cascade)

  @@map("items")
}

model Character {
  id        String         @id @default(uuid())
  userId    String         @map("user_id")
  name      String
  class     CharacterClass
  spec      String
  realm     String
  isActive  Boolean        @default(false) @map("is_active")
  createdAt DateTime       @default(now()) @map("created_at")
  updatedAt DateTime       @updatedAt @map("updated_at")

  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  reserves    Reserve[]
  attendances RaidAttendance[]

  @@unique([name, realm])
  @@map("characters")
}

model Reserve {
  id          String        @id @default(uuid())
  raidId      String        @map("raid_id")
  characterId String        @map("character_id")
  itemName    String        @map("item_name")
  status      ReserveStatus @default(ACTIVE)
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  raid      Raid      @relation(fields: [raidId], references: [id], onDelete: Cascade)
  character Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@unique([raidId, characterId, itemName])
  @@map("reserves")
}
